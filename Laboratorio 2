#define MAX_POLY 100 // Define el número máximo de polinomios que se pueden manejar
#define MAX_DEGREE 10 // Define el mayor grado aceptado para los polinomios

void printPolynomial(int coeff[], int degree) {
    int isFirstTerm = 1;
    for (int i = degree; i >= 0; i--) {
        if (coeff[i] != 0) {
            if (coeff[i] > 0 && !isFirstTerm) {
                printf(" + ");
            } else if (coeff[i] < 0 && !isFirstTerm) {
                printf(" - ");
            } else if (coeff[i] < 0) {
                printf("-");
            }
            
            if (abs(coeff[i]) != 1 || i == 0) {
                printf("%d", abs(coeff[i]));
            }
            if (i > 0) {
                printf("x");
                if (i > 1) {
                    printf("^%d", i);
                }
            }
            isFirstTerm = 0;
        }
    }
    printf("\n");
}

int main() {
    int numPolynomials, maxDegree;

    // Leer el número de polinomios y el mayor grado aceptado
    printf("Ingrese el numero de polinomios: ");
    scanf("%d", &numPolynomials);
    printf("Ingrese el mayor grado aceptado: ");
    scanf("%d", &maxDegree);

    int polynomials[MAX_POLY][MAX_DEGREE + 1] = {0}; // Matriz de coeficientes

    // Leer los coeficientes de los polinomios
    for (int i = 0; i < numPolynomials; i++) {
        printf("Ingrese los coeficientes del polinomio %d (del grado %d al 0):\n", i + 1, maxDegree);
        for (int j = maxDegree; j >= 0; j--) {
            printf("Coeficiente para x^%d: ", j);
            scanf("%d", &polynomials[i][j]);
        }
    }

    int result[MAX_DEGREE + 1] = {0}; // Inicializar el resultado de la suma

    // Sumar los polinomios
    for (int i = 0; i < numPolynomials; i++) {
        for (int j = 0; j <= maxDegree; j++) {
            result[j] += polynomials[i][j];
        }
    }

    // Imprimir el polinomio resultante
    printf("El polinomio resultante es: ");
    printPolynomial(result, maxDegree);

    // Esperar la entrada del usuario antes de cerrar el programa
    printf("Presione Enter para finalizar...");
    getchar(); // Consumir el salto de línea sobrante del último scanf
    getchar(); // Esperar a que el usuario presione Enter

    return 0;
}
